# Copy to .env.local and fill values for local dev.
# In Cloud Run, the non-secret vars come from --set-env-vars and the secrets
# come from --set-secrets (Google Secret Manager).

# Supabase
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# BigQuery
BIGQUERY_PROJECT_ID=sbc-data-int

# GCS
GCS_BUCKET_NAME=

# Resend (emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Superbid Exchange <informes@superbidcolombia.com>

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# OIDC audience expected on /jobs/* (Cloud Scheduler signs tokens with this audience).
# Leave empty in local dev to bypass OIDC validation entirely.
JOBS_OIDC_AUDIENCE=

# Optional: restrict /jobs/* to OIDC tokens issued by a specific SA email.
# Cloud Scheduler signs tokens AS its --oidc-service-account-email; that email
# appears in the token's `email` claim. Defense in depth on top of audience.
JOBS_OIDC_ALLOWED_EMAIL=

# Local dev only: path to GCP service account JSON key.
# In Cloud Run, identity comes from the attached SA — leave this empty.
GOOGLE_APPLICATION_CREDENTIALS=
