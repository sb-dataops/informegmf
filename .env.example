# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and stays on your machine only.
#
# Supabase: URL del proyecto y anon (publishable) key.
# Importante: VITE_SUPABASE_PUBLISHABLE_KEY debe ser la legacy anon JWT (eyJ...),
# no la nueva sb_publishable_... — las Edge Functions exigen JWT en Authorization.
# Obtén ambas con: npx supabase projects api-keys --project-ref <ref>
#
# VITE_API_BASE_URL: URL base de las edge functions o (futuro) Cloud Run.
# Hoy: https://<ref>.supabase.co/functions/v1
# Futuro: https://api.gmf.superbid.com.co (o el dominio que se defina)

VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_API_BASE_URL=
